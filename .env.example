# Copy to .env and fill these in. Never commit the real values.
# Generate a strong secret with: sitepass init  (or: openssl rand -base64 32)

# The shared password every visitor types.
SITEPASS_PASSWORD=

# A random 32+ byte secret that signs session cookies. Keep it private.
SITEPASS_SECRET=

# Optional: lets CI, E2E runs, and uptime monitors pass the gate via the
# x-sitepass-bypass header. Treat it like a password.
# SITEPASS_BYPASS_TOKEN=
