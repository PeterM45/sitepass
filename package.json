{
  "name": "sitepass",
  "version": "0.1.0",
  "description": "Put one shared password in front of any web app. No database, no accounts, no auth provider.",
  "type": "module",
  "license": "MIT",
  "author": "Peter Mangialardi",
  "homepage": "https://github.com/PeterM45/sitepass#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PeterM45/sitepass.git"
  },
  "bugs": {
    "url": "https://github.com/PeterM45/sitepass/issues"
  },
  "keywords": [
    "password",
    "gate",
    "auth",
    "middleware",
    "edge",
    "cloudflare-pages",
    "netlify",
    "next",
    "astro",
    "sveltekit",
    "deployment-protection"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "sitepass": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/core.cjs",
  "module": "./dist/core.js",
  "types": "./dist/core.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/core.d.ts",
        "default": "./dist/core.js"
      },
      "require": {
        "types": "./dist/core.d.cts",
        "default": "./dist/core.cjs"
      }
    },
    "./cloudflare": {
      "import": {
        "types": "./dist/cloudflare.d.ts",
        "default": "./dist/cloudflare.js"
      },
      "require": {
        "types": "./dist/cloudflare.d.cts",
        "default": "./dist/cloudflare.cjs"
      }
    },
    "./netlify": {
      "import": {
        "types": "./dist/netlify.d.ts",
        "default": "./dist/netlify.js"
      },
      "require": {
        "types": "./dist/netlify.d.cts",
        "default": "./dist/netlify.cjs"
      }
    },
    "./next": {
      "import": {
        "types": "./dist/next.d.ts",
        "default": "./dist/next.js"
      },
      "require": {
        "types": "./dist/next.d.cts",
        "default": "./dist/next.cjs"
      }
    },
    "./astro": {
      "import": {
        "types": "./dist/astro.d.ts",
        "default": "./dist/astro.js"
      },
      "require": {
        "types": "./dist/astro.d.cts",
        "default": "./dist/astro.cjs"
      }
    },
    "./sveltekit": {
      "import": {
        "types": "./dist/sveltekit.d.ts",
        "default": "./dist/sveltekit.js"
      },
      "require": {
        "types": "./dist/sveltekit.d.cts",
        "default": "./dist/sveltekit.cjs"
      }
    },
    "./express": {
      "import": {
        "types": "./dist/express.d.ts",
        "default": "./dist/express.js"
      },
      "require": {
        "types": "./dist/express.d.cts",
        "default": "./dist/express.cjs"
      }
    },
    "./hono": {
      "import": {
        "types": "./dist/hono.d.ts",
        "default": "./dist/hono.js"
      },
      "require": {
        "types": "./dist/hono.d.cts",
        "default": "./dist/hono.cjs"
      }
    },
    "./bun": {
      "import": {
        "types": "./dist/bun.d.ts",
        "default": "./dist/bun.js"
      },
      "require": {
        "types": "./dist/bun.d.cts",
        "default": "./dist/bun.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "prepack": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check": "biome check .",
    "format": "biome check --write .",
    "format:unsafe": "biome check --write --unsafe ."
  },
  "peerDependencies": {
    "@sveltejs/kit": ">=2",
    "astro": ">=4",
    "express": ">=4",
    "hono": ">=4",
    "next": ">=13"
  },
  "peerDependenciesMeta": {
    "@sveltejs/kit": {
      "optional": true
    },
    "astro": {
      "optional": true
    },
    "express": {
      "optional": true
    },
    "hono": {
      "optional": true
    },
    "next": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@sveltejs/kit": "^2.61.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "4.1.7",
    "astro": "^6.4.2",
    "express": "^5.2.1",
    "hono": "^4.12.23",
    "next": "^16.2.6",
    "svelte": "^5.56.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
